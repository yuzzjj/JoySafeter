
# 禁用 Next.js 遥测
NEXT_TELEMETRY_DISABLED=1

# Docker 容器内部配置（Node.js 服务器监听的内部端口，通常不需要修改）
# 对应的宿主机端口在 deploy/.env 的 FRONTEND_PORT_HOST 中配置
FRONTEND_PORT=3000

# Content Security Policy (CSP) Extra Connect Sources
# Examples: http://*.jd.com https://*.jd.com ws://*.jd.com wss://*.jd.com
# NEXT_PUBLIC_CSP_CONNECT_SRC_EXTRA="http://*.jd.com https://*.jd.com ws://*.jd.com wss://*.jd.com"
# NEXT_PUBLIC_CSP_FRAME_SRC_EXTRA="http://*.jd.com https://*.jd.com ws://*.jd.com wss://*.jd.com"
