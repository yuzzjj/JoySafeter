
# 禁用 Next.js 遥测
NEXT_TELEMETRY_DISABLED=1

# Docker 容器内部配置
FRONTEND_PORT=3000
FRONTEND_HOSTNAME=0.0.0.0

# Content Security Policy (CSP) Extra Connect Sources
# Examples: http://*.jd.com https://*.jd.com ws://*.jd.com wss://*.jd.com
# NEXT_PUBLIC_CSP_CONNECT_SRC_EXTRA="http://*.jd.com https://*.jd.com ws://*.jd.com wss://*.jd.com"
